# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Vercel Blob — auto-injected on Vercel when Blob store is linked
BLOB_READ_WRITE_TOKEN=

# Protects /api/cron/generate-facts (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Edition date boundary for daily facts (IANA timezone, e.g. Asia/Kolkata or UTC)
CURIO_TIMEZONE=UTC
