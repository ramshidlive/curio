# Gemini — https://aistudio.google.com/apikey (paid tier recommended for Search Grounding)
GEMINI_API_KEY=

# Optional override (default: gemini-2.5-pro)
# GEMINI_MODEL=

# Vercel Blob — Production/Preview only on Vercel; for local seed use:
#   vercel env pull .env.local --environment=production
BLOB_READ_WRITE_TOKEN=

# Protects /api/cron/generate-facts (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Edition date boundary for daily facts (IANA timezone, e.g. Asia/Kolkata or UTC)
CURIO_TIMEZONE=UTC
